pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--main

function _init()
	suit_cols = {8, 8, 0, 0}
	-- hearts, diamonds, clubs, spades
	rank_strs = " 23456789tjqka"
	
	-- init function pointers
	_up, _dp = _update_main, _draw_main
end

function _update()
	_up()
end

function _draw()
	_dp()
end
-->8
--utils

function draw_card(rank, suit, x, y)
	-- pink is transparent
	palt(0, false)
	palt(14, true)
			
	--print card base
	spr(64, x, y, 2, 3)
	
	-- 1: hearts, 2: diamonds, 3: clubs, 4: spades
	local col = suit_cols[suit]
	color(col)
	
	-- number rank is rank + 1, 10-12 is jack-king, 13 is ace
	local rankstr = sub(rank_strs, rank, rank)
	
	-- print rank
	print(rankstr, x+2, y+2)
	print(rankstr, x+11, y+17)
	
	pal(13, col)
	-- print symbol
	spr(65 + suit, x+4, y+8)
	
	-- reset palette
	pal()
	palt()
		
end
-->8
--updates

function _update_game()
	
end
-->8
--draws

function draw_game()
	cls(3)
	draw_card(1,  1, 20, 20)
	draw_card(5,  2, 40, 20)
	draw_card(11, 3, 20, 60)
	draw_card(13, 4, 40, 60)
end
