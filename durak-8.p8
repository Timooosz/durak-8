function _update_game()
	
end
-->8
--draws

function draw_game()
	cls(3)
	draw_card(1,  1, 20, 20)
	draw_card(5,  2, 40, 20)
	draw_card(11, 3, 20, 60)
	draw_card(13, 4, 40, 60)
end
